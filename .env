# Public Sanity config — safe to commit (these ship in the client bundle anyway;
# access is governed by dataset visibility + CORS, not by hiding these values).
# Vercel reads this at build time, so no manual env setup is needed there.
NEXT_PUBLIC_SANITY_PROJECT_ID=6s6voaiy
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-10-01

# Canonical site URL — used for metadata, OG tags, sitemap, robots.
# Update this if you move to a custom domain (e.g. https://siddharthray.com).
NEXT_PUBLIC_SITE_URL=https://siddharthray.vercel.app
